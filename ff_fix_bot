def load_data():
    if os.path.exists(DATA_FILE):
        with open(DATA_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}

def save_data(data):
    with open(DATA_FILE, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=4, ensure_ascii=False)

def is_authorized(user_id):
    return str(user_id) in load_data()

def add_user(user_id, username):
    data = load_data()
    uid = str(user_id)
    if uid not in data:
        data[uid] = {
            "username": username,
            "token_checks": 0,
            "email_checks": 0,
            "spam_actions": 0,
            "join_date": str(datetime.now())
        }
        save_data(data)

def update_stats(user_id, action):
    data = load_data()
    uid = str(user_id)
    if uid in data:
        if action == "token":
            data[uid]["token_checks"] += 1
        elif action == "email":
            data[uid]["email_checks"] += 1
        elif action == "spam":
            data[uid]["spam_actions"] += 1
        save_data(data)

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    user_id = user.id
    username = user.username or "بدون اسم"

    if context.args and context.args[0] == PASSWORD:
        add_user(user_id, username)
        await update.message.reply_text(
            "✅ *تم التسجيل بنجاح!*\nأهلاً بك في البوت المركزي 🤍",
            parse_mode="Markdown"
        )
        await show_menu(update, context)
    elif is_authorized(user_id):
        await show_menu(update, context)
    else:
        await update.message.reply_text(
            f"🔐 *هذا البوت خاص*\n\nللتسجيل، أرسل:\n`/start {PASSWORD}`",
            parse_mode="Markdown"
        )

async def show_menu(update: Update, context: ContextTypes.DEFAULT_TYPE):
    keyboard = [
        [InlineKeyboardButton("🔑 توكن الحساب", callback_data="token")],
        [InlineKeyboardButton("📧 بريد الاستعادة", callback_data="email")],
        [InlineKeyboardButton("💥 سبام احترافي", callback_data="spam")],
        [InlineKeyboardButton("📊 إحصائياتي", callback_data="stats")]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    await update.message.reply_text("📋 *القائمة الرئيسية*\nاختر الخدمة:", reply_markup=reply_markup, parse_mode="Markdown")

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    user_id = query.from_user.id
    
    if not is_authorized(user_id):
        await query.edit_message_text("⛔ غير مصرح لك.")
        return
    
    action = query.data
    
    if action == "token":
        update_stats(user_id, "token")
        await query.edit_message_text(f"🔑 استخدم البوت: {BOTS['token']}\n✅ تم تسجيل العملية.")
    elif action == "email":
        update_stats(user_id, "email")
        await query.edit_message_text(f"📧 استخدم البوت: {BOTS['email']}\n✅ تم تسجيل العملية.")
    elif action == "spam":
        update_stats(user_id, "spam")
        await query.edit_message_text(f"💥 استخدم البوت: {BOTS['spam']}\n✅ تم تسجيل العملية.")
    elif action == "stats":
        data = load_data()
        uid = str(user_id)
        if uid in data:
            s = data[uid]
            text = (f"📊 إحصائياتك:\n🔑 {s['token_checks']}\n📧 {s['email_checks']}\n💥 {s['spam_actions']}")
        else:
            text = "لا توجد إحصائيات"
        await query.edit_message_text(text)

def main():
    print("🚀 جاري تشغيل البوت...")
    app = Application.builder().token(BOT_TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CallbackQueryHandler(button_handler))
    print("✅ البوت شغال بنجاح!")
    app.run_polling()

if __name__ == "__main__":
    main()
