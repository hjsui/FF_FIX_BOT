def log_message(msg):
    """تسجيل الأحداث"""
    with open(LOG_FILE, "a", encoding="utf-8") as f:
        f.write(f"{datetime.now()} - {msg}\n")

def load_data():
    if os.path.exists(DATA_FILE):
        with open(DATA_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}

def save_data(data):
    with open(DATA_FILE, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=4, ensure_ascii=False)

def is_authorized(user_id):
    return str(user_id) in load_data()

def add_user(user_id, username):
    data = load_data()
    uid = str(user_id)
    if uid not in data:
        data[uid] = {
            "username": username,
            "token_checks": 0,
            "email_checks": 0,
            "spam_actions": 0,
            "join_date": str(datetime.now()),
            "last_active": str(datetime.now())
        }
        save_data(data)
        log_message(f"مستخدم جديد: {username} ({user_id})")

def update_stats(user_id, action):
    data = load_data()
    uid = str(user_id)
    if uid in data:
        if action == "token":
            data[uid]["token_checks"] += 1
        elif action == "email":
            data[uid]["email_checks"] += 1
        elif action == "spam":
            data[uid]["spam_actions"] += 1
        data[uid]["last_active"] = str(datetime.now())
        save_data(data)
        log_message(f"تحديث إحصاء: {action} لـ {data[uid]['username']}")

def get_top_users(limit=5):
    """الحصول على أكثر المستخدمين نشاطاً"""
    data = load_data()
    users = []
    for uid, info in data.items():
        total = info["token_checks"] + info["email_checks"] + info["spam_actions"]
        users.append((info["username"], total))
    users.sort(key=lambda x: x[1], reverse=True)
    return users[:limit]

